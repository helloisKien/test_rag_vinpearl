# DA10 — copy thành .env và chỉnh nếu cần. KHÔNG commit .env.
# Postgres
PG_HOST=localhost
PG_PORT=5432
PG_USER=da10
PG_PASSWORD=da10
PG_DB=da10

# OpenSearch
OS_HOST=localhost
OS_PORT=9200
OS_INDEX=idx_hotel_chunks_v1.0
OS_ALIAS=hotel_chunks

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=col_documents_v1.0

# Models
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
EMBED_DIM=1024

# Index version (ghi vào eval/monitoring report header)
INDEX_VERSION=v1.0

# Data paths
DATA_DIR=data
ONTOLOGY_DIR=ontology
GOLDEN_SET=golden_dataset/golden_set_v1.json
